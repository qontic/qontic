<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quantum Double-Slit Experiment Simulator</title>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
    <link rel="stylesheet" href="css/palette.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
    <script src="js/palette.js"></script>
    <script src="js/double-slit.js"></script>
    <style>
        /* ========== CSS Variables for Theming ========== */
        :root {
          /* Light theme (default) */
          --bg-primary: #f8fafc;
          --bg-secondary: #ffffff;
          --bg-tertiary: #f1f5f9;
          --bg-panel: #ffffff;
          --bg-histogram: #ffffff;
          --text-primary: #1e293b;
          --text-secondary: #475569;
          --text-muted: #64748b;
          --border-color: #e2e8f0;
          --border-strong: #cbd5e1;
          --accent-color: #3b82f6;
          --accent-hover: #2563eb;
          --accent-light: #eff6ff;
          --success-color: #10b981;
          --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
          --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06);
          --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05);
          --radius-sm: 4px;
          --radius-md: 6px;
          --radius-lg: 10px;
          --canvas-bg: #ffffff;
          --canvas-border: #1e293b;
          --font-size-base: 15px;
          --font-size-sm: 14px;
          --font-size-xs: 13px;
          --font-size-info: 15px;
        }

        [data-theme="dark"] {
          --bg-primary: #0f172a;
          --bg-secondary: #1e293b;
          --bg-tertiary: #334155;
          --bg-panel: #1e293b;
          --bg-histogram: #ffffff;
          --text-primary: #f1f5f9;
          --text-secondary: #cbd5e1;
          --text-muted: #94a3b8;
          --border-color: #334155;
          --border-strong: #475569;
          --accent-color: #60a5fa;
          --accent-hover: #3b82f6;
          --accent-light: #1e3a5f;
          --success-color: #34d399;
          --shadow-sm: 0 1px 2px rgba(0,0,0,0.3);
          --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.4), 0 2px 4px -1px rgba(0,0,0,0.3);
          --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.5), 0 4px 6px -2px rgba(0,0,0,0.4);
          --canvas-bg: #000000;
          --canvas-border: #3b82f6;
          --font-size-base: 14px;
          --font-size-sm: 13px;
          --font-size-xs: 12px;
          --font-size-info: 14px;
          --slit-open-color: #22c55e;
          --slit-closed-color: #ef4444;
          --tab-inactive-bg: #475569;
        }
        
        /* Dark mode specific overrides */
        [data-theme="dark"] #rationale,
        [data-theme="dark"] #rationale p,
        [data-theme="dark"] #rationale h1,
        [data-theme="dark"] #rationale article {
          color: #f1f5f9;
        }
        
        [data-theme="dark"] #psiTabs .ui-tabs-nav li:not(.ui-state-active) {
          background: #475569;
        }
        
        [data-theme="dark"] #superContainer > .ui-tabs-nav li:not(.ui-state-active) a {
          color: #cbd5e1;
        }
        
        [data-theme="dark"] .ui-slider {
          background: #475569;
          border-color: #475569;
        }
        
        [data-theme="dark"] .ui-slider-range {
          background: var(--accent-color);
        }
        
        [data-theme="dark"] .ui-slider-handle {
          background: #f1f5f9;
          border-color: var(--accent-color);
        }
        
        [data-theme="dark"] #waveRangeLabel {
          color: #f1f5f9;
        }
        
        [data-theme="dark"] #graphics-parameter-container label,
        [data-theme="dark"] #graphics-parameter-container td {
          color: #f1f5f9;
        }
        
        [data-theme="dark"] #toggleSlit1,
        [data-theme="dark"] #toggleSlit2,
        [data-theme="dark"] #toggleWhichPath,
        [data-theme="dark"] .math-slit-btn {
          color: #ffffff;
          border: 1px solid rgba(255,255,255,0.2);
        }

        [data-theme="dark"] #math-container .katex,
        [data-theme="dark"] #math-container .katex .mord,
        [data-theme="dark"] #math-container .katex .mbin,
        [data-theme="dark"] #math-container .katex .mrel,
        [data-theme="dark"] #math-container .katex .mopen,
        [data-theme="dark"] #math-container .katex .mclose,
        [data-theme="dark"] #math-container .katex .mpunct,
        [data-theme="dark"] #math-container .katex .minner {
          color: #f1f5f9;
        }

        /* ========== Base Styles ========== */
        * {
          box-sizing: border-box;
        }

        body {
          font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
          margin: 0;
          padding: 12px;
          background: var(--bg-primary);
          color: var(--text-primary);
          font-size: var(--font-size-base);
          line-height: 1.4;
          transition: background-color 0.3s ease, color 0.3s ease;
        }

        /* ========== Main Layout ========== */
         .main-container {
	    position: relative;
            display: flex;
            gap: 16px;
          }

         #leftPanel {
          display: flex;
          flex-direction: column;
          justify-content: space-between;
          gap: 12px;
          width: 380px;
          min-width: 250px;
          max-width: none;
        }
        
        /* ========== Resizable Panel Handles ========== */
        .ui-resizable-e {
          width: 8px;
          right: -4px;
          background: linear-gradient(90deg, transparent 2px, var(--border-strong) 2px, var(--border-strong) 4px, transparent 4px);
          cursor: ew-resize;
          opacity: 0.6;
          transition: opacity 0.2s;
        }
        .ui-resizable-e:hover { opacity: 1; }
        
        .ui-resizable-s {
          height: 8px;
          bottom: -4px;
          background: linear-gradient(0deg, transparent 2px, var(--border-strong) 2px, var(--border-strong) 4px, transparent 4px);
          cursor: ns-resize;
          opacity: 0.6;
          transition: opacity 0.2s;
        }
        .ui-resizable-s:hover { opacity: 1; }
        
        #canvas-container.ui-resizable {
          overflow: hidden;
        }
	    
        #controls {
            margin-top: 20px;
        }

        .container {
            display: flex;
            flex-direction: column;
        }

        /* ========== Input Groups ========== */
        .input-group {
          display: flex;
          align-items: center;
          margin-bottom: 6px;
          max-width: 100%;
        }
        .input-group label {
          width: 95px;
          margin-right: 4px;
          flex-shrink: 0;
          font-size: var(--font-size-base);
          font-weight: 500;
          color: var(--text-secondary);
        }
        .input-group input[type=range] {
          flex: 1 1 auto;
          margin-right: 4px;
          max-width: 100px;
          accent-color: var(--accent-color);
          height: 5px;
        }
        .input-group input[type=number] {
          width: 5em;
          margin-right: 2px;
          flex-shrink: 0;
          padding: 3px 4px;
          border: 1px solid var(--border-color);
          border-radius: var(--radius-sm);
          background: var(--bg-secondary);
          color: var(--text-primary);
          font-size: var(--font-size-base);
          transition: border-color 0.2s, box-shadow 0.2s;
        }
        .input-group input[type=number]:focus {
          outline: none;
          border-color: var(--accent-color);
          box-shadow: 0 0 0 2px var(--accent-light);
        }
        .input-group select {
          min-width: 45px;
          flex-shrink: 0;
          padding: 4px 6px;
          border: 1px solid var(--border-color);
          border-radius: var(--radius-sm);
          background: var(--bg-secondary);
          color: var(--text-primary);
          font-size: var(--font-size-base);
          cursor: pointer;
        }

        /* ========== Wave Controls Box ========== */
        .wave-range-box {
          border: 1px solid var(--border-color);
          background: var(--bg-tertiary);
          border-radius: var(--radius-md);
          padding: 8px 10px 4px;
          margin-bottom: 8px;
        }

        /* ========== Opacity Controls Box ========== */
        .opacity-box {
          border: 1px solid var(--border-color);
          background: var(--bg-tertiary);
          border-radius: var(--radius-md);
          padding: 6px 10px 4px;
          margin-bottom: 8px;
        }
        .opacity-box-title {
          font-size: var(--font-size-sm);
          font-weight: 600;
          color: var(--text-secondary);
          margin-bottom: 4px;
        }
        .opacity-box .input-group label {
          width: 65px;
        }
        .opacity-box .input-group select {
          display: none;
        }

        #waveFunctionOption,
        #sourceOption {
          min-width: 110px;
        }

        #particle-parameter-container .amplitude-label {
          width: auto;
          margin-left: 8px;
          margin-right: 4px;
        }

        /* Make the Sim. Speed "x" look like plain text, not a dropdown */
        #animationStep-units {
          -webkit-appearance: none;
          -moz-appearance: none;
          appearance: none;
          border: none;
          background: transparent;
          padding: 0;
          pointer-events: none;
          color: var(--text-secondary);
        }

        /* ========== Info Panel ========== */
        #Info {
          display: flex;
          flex-direction: column;
          gap: 10px;
          width: 100%;
          padding: 12px;
          border: 1px solid var(--border-color);
          border-radius: var(--radius-md);
          background: var(--bg-panel);
          box-shadow: var(--shadow-sm);
          font-size: var(--font-size-info);
        }

        /* ========== Tooltips (data-tip, not title, to avoid native double-tooltip) ========== */
        label[data-tip], div[data-tip], tr[data-tip] td.label, td[data-tip]:first-child {
          border-bottom: 1px dotted var(--text-muted);
          cursor: help;
        }
        tr[data-tip] td.label {
          border-bottom: 1px dotted var(--text-muted);
        }
        
        [data-tip] {
          position: relative;
        }
        label[data-tip]:hover::after,
        div[data-tip]:hover::after,
        tr[data-tip]:hover::after,
        td[data-tip]:hover::after,
        canvas[data-tip]:hover::after {
          content: attr(data-tip);
          position: absolute;
          left: 0;
          top: 100%;
          margin-top: 6px;
          background: var(--bg-tertiary);
          color: var(--text-primary);
          padding: 10px 14px;
          border-radius: var(--radius-md);
          font-size: 13px;
          white-space: normal;
          max-width: 300px;
          z-index: 1000;
          pointer-events: none;
          box-shadow: var(--shadow-lg);
          border: 1px solid var(--border-color);
          line-height: 1.5;
          opacity: 0;
          animation: tooltipFadeIn 0s 1s forwards;
        }
        @keyframes tooltipFadeIn {
          to { opacity: 1; }
        }
        #Info tr[data-tip]:hover::after {
          left: 100%;
          top: 50%;
          transform: translateY(-50%);
          margin-left: 10px;
          margin-top: 0;
          white-space: nowrap;
          max-width: none;
        }

        /* ========== Button status lines ========== */
        .btn-status-line {
          font-size: 0.8em;
          color: var(--text-muted);
          min-height: 1.4em;
          margin-top: 4px;
          margin-bottom: 4px;
          line-height: 1.4;
          transition: opacity 0.15s;
        }

        /* ========== Info Panel Layout ========== */
        .info-layout {
          display: flex;
          justify-content: space-between;
          align-items: flex-start;
          gap: 16px;
        }

        .info-metrics table {
          border-collapse: collapse;
          width: 100%;
        }

        .info-metrics td.label {
          padding-right: 18px;
          font-size: 13px;
          color: var(--text-secondary);
        }

        .info-metrics td.value {
          font-weight: 600;
          font-variant-numeric: tabular-nums;
          color: var(--text-primary);
        }

        .info-controls {
          display: flex;
          flex-direction: column;
          gap: 8px;
          align-items: stretch;
        }

        .info-metrics {
          flex: 2;
        }

        .info-controls {
          flex: 1;
        }
	
        #histo-info {
            display: flex;
            flex-direction: column;
            gap: 10px;
            width: 200px;
            padding: 12px;
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            background: var(--bg-panel);
        }


       .histogram {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            width: 200px;
            height: 70px;
            border: 1px solid var(--border-color);
            margin: 16px auto;
            background: var(--bg-histogram);
        }
        .bar {
            width: 30px;
            background-color: var(--accent-color);
            text-align: center;
            margin: 1px;
            position: relative;
        }
        .bar-label {
            font-size: 12px;
            color: #fff;
            position: absolute;
            bottom: 0;
            width: 100%;
	    }

        /* ========== Tab Navigation ========== */
        #psiTabs {
          display: flex;
          flex-direction: column;
          flex: 1 1 auto;
          border: 1px solid var(--border-color);
          border-radius: var(--radius-md);
          background: var(--bg-panel);
          box-shadow: var(--shadow-sm);
          overflow: hidden;
        }

        #psiTabs .ui-tabs-nav {
          display: flex;
          flex-direction: row;
          margin: 0;
          padding: 0;
          border-bottom: 1px solid var(--border-color);
          background: var(--bg-tertiary);
        }

        #psiTabs .ui-tabs-nav li {
          list-style: none;
          display: flex;
          align-items: center;
          justify-content: center;
          padding: 6px 12px;
          cursor: pointer;
          border-right: 1px solid var(--border-color);
          transition: background-color 0.2s;
        }

        #psiTabs .ui-tabs-nav li:hover {
          background: var(--bg-secondary);
        }

        #psiTabs .ui-tabs-nav li:last-child {
          border-right: none;
        }

        #psiTabs .ui-tabs-nav li a {
          display: flex;
          align-items: center;
          justify-content: center;
          text-decoration: none;
          color: var(--text-secondary);
          padding: 2px 0;
          width: 100%;
          height: 100%;
        }

        #psiTabs .tab-icon.material-icons {
          font-size: 20px;
          line-height: 1;
        }

        #psiTabs .tab-icon-svg {
          width: 22px;
          height: 22px;
          display: block;
          color: var(--accent-color);
        }

        /* Per-tab icon colors */
        #psiTabs .tab-physics a { color: var(--accent-color); }
        #psiTabs .tab-physics  .tab-icon { color: var(--accent-color); }
        #psiTabs .tab-setup    .tab-icon { color: #8b5cf6; }
        #psiTabs .tab-graphics .tab-icon { color: #10b981; }
        #psiTabs .tab-it       .tab-icon { color: #f59e0b; }
        #psiTabs .tab-views    .tab-icon { color: #ef4444; }

        #psiTabs .ui-tabs-nav li.ui-state-active {
          background: var(--bg-panel);
          border-bottom: 2px solid var(--accent-color);
          margin-bottom: -1px;
        }

        #psiTabs .ui-tabs-panel {
          flex: 1 1 auto;
          padding: 12px;
          overflow: auto;
          background: var(--bg-panel);
        }
	    
    /* ========== Color Picker Modal ========== */
    #colorPickerModal {
      display: none;
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: var(--bg-panel);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border-color);
      padding: 20px 24px;
      max-height: 80%;
      overflow-y: auto;
      box-shadow: var(--shadow-lg);
      z-index: 1001;
      min-width: 320px;
    }

    #colorPickerModal h3 {
      margin: 0 0 12px;
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
    }

    .palette {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(28px, 1fr));
      gap: 8px;
    }

    .colorOption {
      width: 28px;
      height: 28px;
      border-radius: var(--radius-md);
      border: 2px solid transparent;
      cursor: pointer;
      box-shadow: var(--shadow-sm);
      transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
    }

    .colorOption:hover {
      transform: scale(1.1);
      border-color: var(--accent-color);
      box-shadow: var(--shadow-md);
    }

    #overlay {
      display: none;
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(0,0,0,0.5);
      backdrop-filter: blur(2px);
      z-index: 1000;
    }

   .pick-color {
      width: 32px;
      height: 22px;
      border: 2px solid var(--border-color);
      cursor: pointer;
      border-radius: var(--radius-sm);
      transition: border-color 0.2s;
   }
   .pick-color:hover {
      border-color: var(--accent-color);
   }

        #canvas {
            margin-top: 20px;
        }

  /* ========== Canvas Container ========== */
  #canvas-container {
    position: relative;
    width: 800px;
    height: 600px;
    border: 2px solid var(--canvas-border);
    border-radius: var(--radius-md);
    margin: 20px 0;
    min-width: 400px;
    min-height: 300px;
    max-width: 1200px;
    max-height: 900px;
    background: var(--canvas-bg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
   }
    canvas {
      position: absolute;
    }
    #waveCanvas  { z-index: 0; }
    #setupCanvas { z-index: 1; }
    #partCanvas  { z-index: 2; }

   /* ========== Buttons ========== */
   button {
     font-family: inherit;
     font-size: 13px;
     font-weight: 500;
     padding: 8px 16px;
     border: 1px solid var(--border-color);
     border-radius: var(--radius-sm);
     background: var(--bg-secondary);
     color: var(--text-primary);
     cursor: pointer;
     transition: all 0.2s ease;
   }

   button:hover {
     background: var(--bg-tertiary);
     border-color: var(--accent-color);
   }

   button:active {
     transform: translateY(1px);
   }

   #startButton, #resetButton {
     min-width: 90px;
     padding: 10px 16px;
     font-weight: 600;
   }

   #startButton {
     background: var(--accent-color);
     color: white;
     border-color: var(--accent-color);
   }

   #startButton:hover {
     background: var(--accent-hover);
     border-color: var(--accent-hover);
   }

   #resetButton {
     background: #b91c1c;
     color: white;
     border-color: #b91c1c;
   }

   #resetButton:hover {
     background: #991b1b;
     border-color: #991b1b;
   }

   #toggleSlit1, #toggleSlit2, #toggleWhichPath, .math-slit-btn {
     background: var(--accent-color);
     color: white;
     border-color: var(--accent-color);
     min-width: 100px;
     padding: 8px 12px;
     font-weight: 500;
   }

   #toggleSlit1:hover, #toggleSlit2:hover, #toggleWhichPath:hover, .math-slit-btn:hover {
     background: var(--accent-hover);
     border-color: var(--accent-hover);
   }

   .button-group {
     display: flex;
     gap: 10px;
     margin-top: 10px;
   }

   .interp-btn {
     padding: 10px 18px;
     border: 1px solid var(--border-color);
     background: var(--bg-secondary);
     cursor: pointer;
     font-weight: 600;
     border-radius: var(--radius-sm);
     transition: all 0.2s;
   }

   .interp-btn.active {
     background: var(--accent-color);
     color: white;
     border-color: var(--accent-color);
     cursor: default;
   }

   .views-buttons {
     display: flex;
     flex-direction: column;
     gap: 8px;
   }

   .particle-second-line {
     display: block;
     margin-top: 2px;
   }

   /* ========== Branch Counter ========== */
   #worldCountDisplay {
     font-size: 1.3em;
     font-weight: 600;
     color: var(--accent-color);
     background: var(--accent-light);
     padding: 10px 14px;
     border-radius: var(--radius-md);
     box-shadow: var(--shadow-sm);
     text-align: center;
     border: 1px solid var(--border-color);
   }

   #worldCountDisplay {
     animation: pulse 2s infinite;
   }

   @keyframes pulse {
     0%   { transform: scale(1); }
     50%  { transform: scale(1.02); }
     100% { transform: scale(1); }
   }
   
  .branch-button {
    background: linear-gradient(135deg, var(--accent-color), var(--accent-hover));
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    padding: 10px 18px;
    font-size: 1rem;
    font-weight: 500;
    box-shadow: var(--shadow-md);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
  }

  .branch-button:hover {
    transform: scale(1.03);
    box-shadow: var(--shadow-lg);
  }
   
  #worldFactor {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-tertiary);
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
  }

  /* ========== Checkboxes ========== */
  input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--accent-color);
    cursor: pointer;
  }

  /* ========== Super Container Tabs ========== */
  #superContainer.ui-tabs {
    background: transparent;
    border: none;
    padding: 0;
  }

  #superContainer > .ui-tabs-nav {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    padding: 0;
    margin-bottom: 0;
  }

  #superContainer > .ui-tabs-nav li {
    margin: 0;
    border: none;
    background: transparent;
  }

  #superContainer > .ui-tabs-nav li a {
    padding: 12px 20px;
    color: var(--text-secondary);
    font-weight: 500;
  }

  #superContainer > .ui-tabs-nav li.ui-state-active {
    background: var(--bg-panel);
    border-bottom: 2px solid var(--accent-color);
  }

  #superContainer > .ui-tabs-nav li.ui-state-active a {
    color: var(--text-primary);
  }

  #superContainer > .ui-tabs-panel {
    border: 1px solid var(--border-color);
    border-top: none;
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    background: var(--bg-primary);
    padding: 20px;
  }

  /* ========== Timing Fieldset ========== */
  fieldset {
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 8px 12px;
    background: var(--bg-tertiary);
  }

  fieldset legend {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    padding: 0 6px;
  }

  fieldset table {
    font-size: 12px;
    color: var(--text-secondary);
  }

    </style>
</head>
<body>
  <div id="superContainer" class="container">
    <ul>
      <li><a href="#mainContainer" >Simulation</a></li>
      <li><a href="#rationale" >Rationale</a></li>
    </ul>
  <div id="mainContainer" class="container" style="display: flex; flex-direction: column; align-items: center;">
   <!--<div id="waveFunctionPlot" style="width:600px;height:600px;"></div> -->
   <div class="main-container">
     <div id="leftPanel">
     <div id="psiTabs" class="container">
        <ul>
      	    <li class="tab-physics"><a href="#particle-parameter-container" title="Physics">
                  <svg class="tab-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                    <!-- nucleus -->
                    <circle cx="12" cy="12" r="3" fill="currentColor" opacity="0.3" stroke="currentColor" stroke-width="1.1"/>
                    <!-- three stylized orbits -->
                    <ellipse cx="12" cy="12" rx="8" ry="4" fill="none" stroke="currentColor" stroke-width="1"/>
                    <ellipse cx="12" cy="12" rx="8" ry="4" fill="none" stroke="currentColor" stroke-width="1" transform="rotate(60 12 12)"/>
                    <ellipse cx="12" cy="12" rx="8" ry="4" fill="none" stroke="currentColor" stroke-width="1" transform="rotate(120 12 12)"/>
                    <!-- small electrons -->
                    <circle cx="19" cy="12" r="1.2" fill="#f59e0b"/>
                    <circle cx="8" cy="5" r="1.2" fill="#f59e0b"/>
                    <circle cx="7" cy="18" r="1.2" fill="#f59e0b"/>
                  </svg>
                </a></li>
            <li class="tab-setup"><a href="#detector-parameter-container" title="Setup">
                  <span class="material-icons tab-icon" aria-hidden="true">build</span>
                </a></li>
            <li class="tab-math"><a href="#math-container" title="Math">
                  <span class="material-icons tab-icon" aria-hidden="true">functions</span>
                </a></li>
            <li class="tab-graphics"><a href="#graphics-parameter-container" title="Graphics">
                  <span class="material-icons tab-icon" aria-hidden="true">bar_chart</span>
                </a></li>
      	    <li class="tab-views"><a href="#ontology" title="Views">
                  <span class="material-icons tab-icon" aria-hidden="true">visibility</span>
                </a></li>
        </ul>
	<div id="detector-parameter-container" style="padding-top: 12px;"> 
            <button id="toggleSlit1" title="Open or close slit 1. At least one slit must remain open.">Slit 1: Open</button>
            <button id="toggleSlit2" title="Open or close slit 2. At least one slit must remain open.">Slit 2: Open</button>
            <button id="toggleWhichPath" title="Cycle the which-path detector: No Detector → Detector at Slit 1 → Detector at Slit 2. A detector collapses the interference pattern into single-slit diffraction.">No Det</button>
	    <br><br>
	    <!-- Wave visibility controls for detector mode -->
	    <div id="detectorWaveControls" style="display: none; margin-bottom: 10px; padding: 10px; border: 1px solid var(--border-color); border-radius: var(--radius-md); background: var(--bg-input);">
	      <div style="font-weight: 600; margin-bottom: 8px; color: var(--text-primary);">Wave Controls</div>
	      
	      <!-- Wave 1 controls -->
	      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
	        <input type="checkbox" id="showWaveSlit1" checked>
	        <label for="showWaveSlit1" style="width: 55px; color: var(--text-primary);">Wave 1</label>
	        <input type="range" id="wave1Opacity" min="0" max="100" value="50" style="width: 80px;">
	        <span id="wave1OpacityVal" style="width: 30px; font-size: 11px; color: var(--text-primary);">50%</span>
	        <canvas title="Select Palette for Wave 1" id="openPalette1Btn" width="40" height="16" style="cursor: pointer; border: 1px solid var(--border-color); border-radius: 2px;"></canvas>
	      </div>
	      
	      <!-- Wave 2 controls -->
	      <div style="display: flex; align-items: center; gap: 8px;">
	        <input type="checkbox" id="showWaveSlit2" checked>
	        <label for="showWaveSlit2" style="width: 55px; color: var(--text-primary);">Wave 2</label>
	        <input type="range" id="wave2Opacity" min="0" max="100" value="50" style="width: 80px;">
	        <span id="wave2OpacityVal" style="width: 30px; font-size: 11px; color: var(--text-primary);">50%</span>
	        <canvas title="Select Palette for Wave 2" id="openPalette2Btn" width="40" height="16" style="cursor: pointer; border: 1px solid var(--border-color); border-radius: 2px;"></canvas>
	      </div>
	    </div>
	</div>

        <div id="ontology">
           <div class="views-buttons">
             <button title="In this view, particles are detected at the screen without trajectories, consistent with the standard quantum formalism where only measurement outcomes are predicted" class="interp-btn active" data-mode="copenhagen">Measurement-Based</button>
             <button title="In this view, each particle follows a definite trajectory guided by the wave function, as in the de Broglie–Bohm pilot-wave theory. The resulting distribution reproduces standard quantum predictions" class="interp-btn" data-mode="bohmian">Trajectory-Based</button>
             <button title="This view illustrates the Everettian idea that a quantum measurement leads to multiple, coexisting branches of reality corresponding to different possible outcomes. The simulation tracks these branching alternatives as a pedagogical heuristic consistent with unitary evolution and decoherence. It is not intended as a literal calculation of the number of physical worlds" class="interp-btn" data-mode="manyworlds">Wave-Only</button>
           </div>
           <div id="manyBranchesInfo">
       <center>
      <div title="Number of branches produced since the beginning of the simulation" id="worldCountDisplay">Branch Count: 1</div>
      <div title="Increase in the number of worlds per detector hit" id="worldFactor">Increase in # Branches pet Hit: 100</div>
      <button id="resampleHitsButton" class="branch-button">See Hits Detected in Another Branch</button>
      <button id="resetBranches" class="branch-button">Reset Branches</button>
       </center>
     </div>
  </div>

        <!-- Math / Formulas tab -->
        <div id="math-container" style="padding-top: 12px;">
          <h3 style="margin: 0 0 12px 0; font-size: 1.05em; color: var(--text-primary);">Wave Function</h3>

          <div style="margin-bottom: 10px;">
            <button id="mathToggleSlit1" title="Open or close slit 1. At least one slit must remain open." class="math-slit-btn">Slit 1: Open</button>
            <button id="mathToggleSlit2" title="Open or close slit 2. At least one slit must remain open." class="math-slit-btn">Slit 2: Open</button>
            <button id="mathToggleWhichPath" title="Cycle the which-path detector: No Detector → Detector at Slit 1 → Detector at Slit 2. A detector collapses the interference pattern into single-slit diffraction." class="math-slit-btn">No Det</button>
          </div>

          <div style="margin-bottom: 16px;">
            <div style="font-weight: 600; font-size: 0.9em; color: var(--text-secondary); margin-bottom: 6px;">Domain 1 &mdash; Before the wall</div>
            <div id="mathDomain1" style="padding: 8px 10px; background: var(--bg-tertiary); border-radius: var(--radius-md); border: 1px solid var(--border-color); overflow-x: auto;"></div>
          </div>

          <div style="margin-bottom: 16px;">
            <div style="font-weight: 600; font-size: 0.9em; color: var(--text-secondary); margin-bottom: 6px;">Domain 2 &mdash; After the wall</div>
            <div id="mathDomain2" style="padding: 8px 10px; background: var(--bg-tertiary); border-radius: var(--radius-md); border: 1px solid var(--border-color); overflow-x: auto;"></div>
          </div>

          <div id="mathDetectorNote" style="display: none; margin-bottom: 16px;">
            <div style="font-weight: 600; font-size: 0.9em; color: var(--text-secondary); margin-bottom: 6px;">Detector state</div>
            <div id="mathDetectorExplain" style="padding: 8px 10px; background: var(--bg-tertiary); border-radius: var(--radius-md); border: 1px solid var(--border-color); overflow-x: auto; font-size: 0.88em; color: var(--text-primary); line-height: 1.6;"></div>
          </div>

          <div id="mathBohmSection" style="margin-bottom: 16px;">
            <div style="font-weight: 600; font-size: 0.9em; color: var(--text-secondary); margin-bottom: 6px;">Particle velocity</div>
            <div id="mathBohmV" style="padding: 8px 10px; background: var(--bg-tertiary); border-radius: var(--radius-md); border: 1px solid var(--border-color); overflow-x: auto;"></div>
          </div>

          <div style="font-size: 0.82em; color: var(--text-muted); line-height: 1.5;">
            <div id="mathLegend"></div>
          </div>
        </div>

        <div id="particle-parameter-container">
          <div class="wave-range-box">
            <div class="input-group">
              <label title="What to show for the wave visualization" for="waveFunctionOption">Show:</label>
              <select id="waveFunctionOption">
	        <option value="Phase">&Psi; phase</option>
	        <option value="LogPsi2">log(|&Psi;|&sup2;)</option>
	        <option value="QPotential">sgn(Q)log(|Q|)</option>
              </select>
            </div>

            <!-- Wave value range control: double slider to window/rescale values shown -->
            <div class="input-group" id="waveRange-group" style="margin-bottom: 4px;">
              <label title="Select the range of wave values shown and rescaled into the color palette" for="waveRangeSlider">Range:</label>
              <div id="waveRangeSlider" style="flex: 1; margin-right: 6px;"></div>
              <span id="waveRangeLabel" style="min-width: 120px; text-align: right; font-size: 0.85em;"></span>
            </div>
          </div>

          <div class="input-group">
            <label title="Whether the wave function is shown continous or for each particle" for="wave-type">Continuous:</label>
            <input id="wave-continous" type="checkbox" checked>
          </div>

          <div class="input-group">
            <label title="If checked, particles are effectively generated from detector-wall hits so all trajectories terminate on the wall. If unchecked, particles are emitted from the source and can reach the detector or escape through the upper/lower boundaries." for="onlyWallMode">Only wall hits:</label>
            <input id="onlyWallMode" type="checkbox">
          </div>

          <div class="input-group particle-second-line">
            <label title="Particle distribution from the source" for="Source">Source:</label>
            <select id="sourceOption">
              <option value="slits">Slits</option>
              <option value="isotropic">Isotropic</option>
            </select>&nbsp;
            <select id="particleType">
              <option value="electron">Electron</option>
              <option value="neutron">Neutron</option>
              <!--<option value="photon">Photon</option>-->
            </select>
          </div>
        </div>
        <div id="graphics-parameter-container">
        <!-- Theme and Font Size Controls -->
        <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 10px; padding-bottom: 8px; border-bottom: 1px solid var(--border-color);">
          <label style="display: flex; align-items: center; gap: 6px; cursor: pointer; color: var(--text-primary);">
            <input type="checkbox" id="darkModeToggle" onchange="toggleTheme()">
            <span>Dark Mode</span>
          </label>
          <div style="display: flex; align-items: center; gap: 4px; color: var(--text-primary);">
            <span>Font:</span>
            <select id="fontTarget" style="padding: 2px 4px; font-size: 12px;">
              <option value="controls">Controls</option>
              <option value="info">Info</option>
            </select>
            <button onclick="changeFontSize(-1)" style="padding: 2px 8px; min-width: 28px;">−</button>
            <span id="fontSizeDisplay" style="min-width: 35px; text-align: center;">14px</span>
            <button onclick="changeFontSize(1)" style="padding: 2px 8px; min-width: 28px;">+</button>
          </div>
        </div>
	<table>
           <tr><Td><label title="Whether to show the detector hit histogram. Their color can be selected." > <input type="checkbox" id="plot_hits" class='replot' checked> Hits  </label>
	   <td><button id="hit-color" title="Select Hit Color" class="pick-color"></button>
           <Td>&nbsp;&nbsp;&nbsp;&nbsp;
           <Td><label title="Whether to show the hits in a color band on the right. It simulates a film response. The film color can be selected"> <input type="checkbox" id="plot_sensor"  class='replot' checked> Sensor  </label>
	   <td><button id="sensor-color" title="Select Sensor Color" class="pick-color"></button>

           <tr>
	   <td><label title="Whether to show the probability of detecting a hit in a particular position on the screen given by the square of the wave function. The line color can also be selected."> <input type="checkbox" id="hit_prob" class='replot' checked> Det. Prob.</label>
	   <td><button id="prob-color" title="Select Hit Probability Color" class="pick-color"></button>
           <Td>
	   <td><label title="Whether trajectores are shown. Their color can be selected."> <input type="checkbox" id="plot_trajectories" class='replot' checked> Traj. </label>
	   <td> <button id="traj-color" title="Select Trajectory Color" class="pick-color"></button>
		   
	   <Tr>
           <Td><label title="Whether the particles are shown. Their color can be selected."> <input type="checkbox" id="plot_particles" class='replot' checked> Particles </label>
	   <td> <button id="part-color" title="Select Particle Color" class="pick-color"></button>
	   <Td>	   
	   <Td><label title="Whether the dimensions on the top left are shown. Their color can be selected."><input type="checkbox" class='replot' id="plot_scales" checked> Scales </label>
	   <td> <button id="scale-color" title="Select Scale Color" class="pick-color"></button>

	   <tr>	   
	  <Td><label title="Whether the detector is shown. Its color can be selected."><input type="checkbox" id="plot_detector"  class='replot' checked> Detector</label>
	   <td> <button  id="detector-color" title="Select Detector Color" class="pick-color"></button>
	   <Td>	   
	   <Td><label title="Whether the screen with the slits is shown. Its color can be selected."><input type="checkbox" id="plot_screen" class='replot' checked>Screen</label> 
	   <td> <button id="screen-color" title="Select Screen Color" class="pick-color"></button>

          </tr>
          <tr>
           <td>
             <label title="Whether the wave or Q are shown. The palette of the image can be selected.">
               <input type="checkbox" id="plot_wave" class="replot" checked> Psi
             </label>
           </td>
           <td>
             <canvas title="Select Graph Palette" id="openPaletteBtn" width="50" height="20" style="position:static; margin: 0; vertical-align: top;"></canvas>
           </td>
	   <td></td>
           <td>
             <label title="Whether the palette is shown.">
               <input type="checkbox" id="plot_palette" checked> Palette
             </label>
           </td>
          </tr>
        </table>
        </div>
    </div>
	
    <div id="Info" class="container">
     <div class="info-layout">
     <div class="info-metrics">
     <table>
	      <tr title="Elapsed simulation time since the start or last reset">
               <td class="label">Sim. Time:</td>
		      <td align=right class="value" id="systemTime">0</td><td>
              </tr>
              <tr title="Elapsed real time (your clock) since the start or last reset">
               <td class="label">Real Time:</td>
	       <td align=right class="value" id="realTime">0</td><td> 
             </tr>
              <tr title="Phase velocity of the quantum wave (ω/k)">
               <td class="label">Wave Speed:</td>
	       <td align=right class="value" id="waveSpeed">0</td><td> 
             </tr>
              <tr title="Kinetic energy of particles based on de Broglie wavelength: E = h²/(2mλ²)">
               <td class="label">Energy:</td>
	       <td align=right class="value" id="particleEnergy">0</td><td> 
             </tr> 
           <tr class="info-box" title="Particles currently shown / maximum allowed">
               <td class="label">Particles:</td>
               <td align=right class="value"><span id="shownParticles">0</span> / <span id="maxParticlesDisplay">100</span></td> 
           </tr>
           <tr class="info-box" title="Detector hits / simulation steps completed">
               <td class="label">Hits/Steps:</td>
               <td align=right class="value"><span id="nhits">0</span>/<span id="nSteps">0</span></td> 
           </tr>
           </table>
     </div>
     <div class="info-controls">
     <button style="width:100px" id="startButton">Start</button>
     <button style="width:100px" id="resetButton">Reset</button>
     <fieldset style="margin-top: 8px; padding: 4px 8px; border: 1px solid #ccc; border-radius: 4px;">
       <legend style="font-size: 14px; padding: 0 4px;">Timing (ms)</legend>
       <table style="font-size: 14px; width: 100%;">
         <tr>
           <td title="Average total time per simulation step">Step:</td>
           <td align="right" id="stepTime">0</td>
         </tr>
       </table>
     </fieldset>
     </div>
     </div>

             </div>

             </div><!-- end leftPanel -->

             <div id="canvas-container">
           <canvas id="setupCanvas" width="800" height="600"></canvas>
           <canvas id="waveCanvas" width="800" height="600"></canvas>
           <canvas id="partCanvas" width="800" height="600"></canvas>
           <canvas id="paletteScaleCanvas" width="40" height="200" title="Color palette scale showing the mapping from wave values to colors. Adjust with the Range slider in the Physics tab." style="position: absolute; left: 0px; bottom: 0px; z-index: 10;"></canvas>
           <canvas id="paletteScaleCanvas2" width="40" height="100" title="Wave 2 (slit 2) color palette scale" style="position: absolute; left: 0px; bottom: 0px; z-index: 10; display: none;"></canvas>
           <canvas id="paletteScaleCanvas1" width="40" height="100" title="Wave 1 (slit 1) color palette scale" style="position: absolute; left: 0px; bottom: 100px; z-index: 10; display: none;"></canvas>
             </div>
<!--
    <div id="histo-info">
       <div id="Phi1" class="histogram"></div>
       <div id="Phi2" class="histogram"></div>
    </div>

    -->
    <div id="controls">
    </div>
  <div id="overlay"></div>
  <div id="colorPickerModal">
    <h3>Select a Color</h3>
    <div class="palette" id="palette"></div>
  </div>
  </div>
</div>
  <div id="rationale">
<p>
  
<article>
    <header>
    <h1>The Double-Slit Experiment</h1>
    </header>


    <p>The double-slit experiment was first performed by Thomas Young in 1801 to demonstrate the wave behavior of visible light. In 1927, at the advent of quantum mechanics, the experiment was reproduced with electrons, and since then, with atoms and ever larger molecules. The observations are qualitatively the same.</p>

    <p>A beam of particles is directed at a plate with two small, parallel slits. On a detector screen behind, one observes an interference pattern, alternating bands of high and low intensity. Crucially, this interference pattern is created by the statistical distribution of individual impact points. If one sends in a single particle at a time, each produces a small dot on the screen in a seemingly random position. A large number of particles build up the interference pattern: alternating regions where many particles are detected and regions where few or none are.</p>

    <p>Interference is a typical wave phenomenon: when two waves overlap, their amplitudes combine, so that in some places, the waves reinforce each other (<strong>constructive interference</strong>), while in others, they reduce or cancel each other (<strong>destructive interference</strong>). On the other hand, the individual dots appearing on the screen suggest the impact of localized particles rather than extended waves.</p>

    <p>The double-slit experiment is therefore a key demonstration of the so-called <em>wave-particle duality</em>. The microscopic constituents of light and matter, photons, electrons, atoms, etc., exhibit both wave-like and particle-like properties.</p>

<p>Different representational approaches motivate different explanatory narratives about the same interference pattern. This demo includes (i) trajectory-based visualizations, (ii) measurement-centered renderings, and (iii) wave-only views. These modes are intended to support comparison of explanatory strategies rather than to endorse a single interpretation.

    <p style="font-size: 0.85em; color: var(--text-muted);">
    <strong>Note:</strong> The screen must interact with the particles in order to detect them. The simulation ignores the effect of this interaction on the particle&lsquo;s wave function and trajectories. In most cases, this effect is small, but in principle, it could alter the trajectories, especially in situations where the detector screen is placed very close to the slits.</p>


  </article>


  </div>

</div>
</div>
<!-- Popup -->
<div id="palettePopup">
  <h3>Select a Color Palette</h3>
  <button id="closePopupBtn">Close</button>
</div>

<!-- Popup for Wave 1 palette -->
<div id="palettePopup1" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: var(--bg-panel); border-radius: var(--radius-lg); border: 1px solid var(--border-color); padding: 20px 24px; max-height: 80%; overflow-y: auto; box-shadow: var(--shadow-lg); z-index: 1001; min-width: 320px;">
  <h3>Select Palette for Wave 1</h3>
  <button id="closePopup1Btn" onclick="$('#palettePopup1').hide()">Close</button>
</div>

<!-- Popup for Wave 2 palette -->
<div id="palettePopup2" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: var(--bg-panel); border-radius: var(--radius-lg); border: 1px solid var(--border-color); padding: 20px 24px; max-height: 80%; overflow-y: auto; box-shadow: var(--shadow-lg); z-index: 1001; min-width: 320px;">
  <h3>Select Palette for Wave 2</h3>
  <button id="closePopup2Btn" onclick="$('#palettePopup2').hide()">Close</button>
</div>

<div id="versionInfo" style="text-align: center; font-size: 0.85em; color: var(--text-muted); margin-top: 16px; padding: 12px; border-top: 1px solid var(--border-color);"> Quantum Simulation Framework v1.0</div>
<!-- Visitor counter removed to avoid browser warnings about
  parser-blocking cross-site scripts injected via document.write. -->

<script>
  // Theme Toggle Functionality
  function toggleTheme() {
    const html = document.documentElement;
    const checkbox = document.getElementById('darkModeToggle');
    const newTheme = checkbox.checked ? 'dark' : 'light';
    html.setAttribute('data-theme', newTheme);
    localStorage.setItem('theme', newTheme);
    // Re-render scales with updated theme colors
    if (typeof renderSetup === 'function') {
      renderSetup();
    }
  }

  // Font Size Control
  let controlsFontSize = 15;
  let infoFontSize = 15;
  
  function changeFontSize(delta) {
    const target = document.getElementById('fontTarget').value;
    const display = document.getElementById('fontSizeDisplay');
    
    if (target === 'controls') {
      controlsFontSize = Math.max(10, Math.min(20, controlsFontSize + delta));
      document.documentElement.style.setProperty('--font-size-base', controlsFontSize + 'px');
      document.documentElement.style.setProperty('--font-size-sm', (controlsFontSize - 1) + 'px');
      document.documentElement.style.setProperty('--font-size-xs', (controlsFontSize - 2) + 'px');
      display.textContent = controlsFontSize + 'px';
      localStorage.setItem('controlsFontSize', controlsFontSize);
    } else {
      infoFontSize = Math.max(10, Math.min(20, infoFontSize + delta));
      document.documentElement.style.setProperty('--font-size-info', infoFontSize + 'px');
      display.textContent = infoFontSize + 'px';
      localStorage.setItem('infoFontSize', infoFontSize);
    }
  }
  
  // Update display when target changes
  document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('fontTarget').addEventListener('change', function() {
      const display = document.getElementById('fontSizeDisplay');
      display.textContent = (this.value === 'controls' ? controlsFontSize : infoFontSize) + 'px';
    });
  });

  // Load saved preferences on page load
  (function() {
    const savedTheme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', savedTheme);
    
    const savedControlsFontSize = localStorage.getItem('controlsFontSize');
    const savedInfoFontSize = localStorage.getItem('infoFontSize');
    if (savedControlsFontSize) {
      controlsFontSize = parseInt(savedControlsFontSize);
    }
    if (savedInfoFontSize) {
      infoFontSize = parseInt(savedInfoFontSize);
    }
    
    // Update UI after DOM is ready
    document.addEventListener('DOMContentLoaded', function() {
      const checkbox = document.getElementById('darkModeToggle');
      if (checkbox) {
        checkbox.checked = savedTheme === 'dark';
      }
      document.documentElement.style.setProperty('--font-size-base', controlsFontSize + 'px');
      document.documentElement.style.setProperty('--font-size-sm', (controlsFontSize - 1) + 'px');
      document.documentElement.style.setProperty('--font-size-xs', (controlsFontSize - 2) + 'px');
      document.documentElement.style.setProperty('--font-size-info', infoFontSize + 'px');
      const display = document.getElementById('fontSizeDisplay');
      if (display) display.textContent = controlsFontSize + 'px';
    });
  })();
</script>

</body>
</html>
